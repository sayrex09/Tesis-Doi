# Copia este archivo como .streamlit/secrets.toml y completa los valores reales.
# No subas .streamlit/secrets.toml a Git.

[google_sheets]
spreadsheet_id = "1keQ5XgJu-dHpIyhcHqmNXUc6GRiw3wp8XEeh2nWddfQ"
# Si lo dejas vacío, se usará la primera pestaña del Google Sheets.
worksheet_name = "Articulos"

[gcp_service_account]
type = "service_account"
project_id = "TU_PROJECT_ID"
private_key_id = "TU_PRIVATE_KEY_ID"
private_key = """-----BEGIN PRIVATE KEY-----
TU_PRIVATE_KEY
-----END PRIVATE KEY-----"""
client_email = "TU_SERVICE_ACCOUNT@TU_PROJECT_ID.iam.gserviceaccount.com"
client_id = "TU_CLIENT_ID"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/TU_SERVICE_ACCOUNT%40TU_PROJECT_ID.iam.gserviceaccount.com"
universe_domain = "googleapis.com"
